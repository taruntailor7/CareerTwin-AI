generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                 String       @id @default(uuid())
  // Not unique — a single Clerk account can own multiple profiles (e.g. exploring different
  // career tracks) which the user switches between in the UI.
  clerkUserId        String
  label              String       @default("")
  fullName           String
  // Not unique — the same person's email appears across every profile they own.
  email              String
  currentRole        String
  yearsExperience    Int
  goals              String[]
  preferredRoles     String[]
  dreamCompanies     String[]
  preferredCountries String[]
  locationPreference String
  expectedSalary     Int?
  currentSalary      Int?
  noticePeriodWeeks  Int?
  education          String[]
  technicalSkills    String[]
  softSkills         String[]
  languages          String[]
  certifications     String[]
  achievements       String[]
  projects           String[]
  portfolioUrl       String?
  githubUrl          String?
  linkedinUrl        String?
  resumeText         String?
  careerMotivation   String
  workStyle          String
  riskTolerance      String
  interviewInsights  String[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  twins              Twin[]
  simulations        Simulation[]
  reports            Report[]
  analyses           Analysis[]
  interviews         InterviewSession[]

  @@index([clerkUserId])
}

model Twin {
  id                  String   @id @default(uuid())
  profileId           String
  summary             String
  strengths           String[]
  growthAreas         String[]
  confidenceMin       Float
  confidenceMax       Float
  careerArchetype     String   @default("Focused Individual Contributor")
  marketPositioning   String   @default("")
  recommendedNextSteps String[]
  dataCompleteness    Int      @default(50)
  createdAt           DateTime @default(now())
  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Simulation {
  id            String   @id @default(uuid())
  profileId     String
  recommendation String
  assumptions   String[]
  tradeoffs     String[]
  confidenceMin Float
  confidenceMax Float
  scenariosJson Json
  evidenceJson  Json
  createdAt     DateTime @default(now())
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reports       Report[]
}

model Report {
  id           String   @id @default(uuid())
  profileId    String
  simulationId String
  title        String
  audience     String
  summary      String
  status       String
  createdAt    DateTime @default(now())
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
}

model Analysis {
  id                       String   @id @default(uuid())
  profileId                String
  source                   String
  score                    Int
  dimensionScoresJson      String
  strengths                String[]
  gaps                     String[]
  recommendations          String[]
  recruiterPerspective     String
  hiringManagerPerspective String
  createdAt                DateTime @default(now())
  profile                  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model InterviewSession {
  id          String   @id @default(uuid())
  profileId   String
  answeredJson String
  nextQuestion String?
  isComplete  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
